# Server configuration
SERVER_PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/todoapp?sslmode=disable

# JWT configuration
JWT_SECRET=your-secret-key-minimum-32-characters!!
JWT_EXPIRATION=24h

# Refresh token expiry
TOKEN_EXPIRY=168h

# CORS
CORS_ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=info

# Database pool
DB_MAX_CONNS=25
DB_MIN_CONNS=5
